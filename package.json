{
  "name": "i18n-tool",
  "version": "2.0.0",
  "description": "Enterprise i18n translation management desktop application",
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/theaob/i18n-tool.git"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && electron-builder",
    "build:renderer": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:e2e": "playwright test",
    "lint": "eslint src electron"
  },
  "keywords": [
    "i18n",
    "translation",
    "localization",
    "electron",
    "desktop"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^29.7.0",
    "concurrently": "^8.2.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "jest": "^29.7.0",
    "vite": "^8.1.3",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.3.1",
    "electron-store": "^8.2.0"
  },
  "build": {
    "appId": "com.i18ntool.app",
    "productName": "i18n Tool",
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}